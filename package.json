{
  "name": "mcp-guardian",
  "version": "1.0.0",
  "description": "Security scanner & runtime proxy for MCP (Model Context Protocol) servers",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mcp-guardian": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "scan": "tsx src/cli.ts scan",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "security",
    "scanner",
    "proxy",
    "llm",
    "ai-safety"
  ],
  "author": "yuga-hashimoto",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yuga-hashimoto/mcp-guardian.git"
  },
  "bugs": {
    "url": "https://github.com/yuga-hashimoto/mcp-guardian/issues"
  },
  "homepage": "https://github.com/yuga-hashimoto/mcp-guardian#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "jsonc-parser": "^3.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}